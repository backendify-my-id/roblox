# Database Settings (PostgreSQL di STB 2)
DB_TYPE=postgres
DB_HOST=192.168.1.11        # IP LAN STB 2 Anda tempat Postgres berjalan
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=roblox
DB_SCHEMA=public

# Redis Settings (Redis di STB 1 secara Remote)
