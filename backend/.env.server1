REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_TTL=120
REDIS_DB=0

# App Settings
# INSTANCE_ID=1              # Dinonaktifkan: Menggunakan deteksi otomatis via Redis
# TOTAL_INSTANCES=2          # Dinonaktifkan: Menggunakan deteksi otomatis via Redis
NODE_ENV=production
APP_PORT=7000
APP_URL=http://localhost:7000
APP_SECRET=86fb2b8d54096f17b9085173f4dd212e3e83dfd22c6656c406d9b876c85e8cf7

