# Database Settings
DB_TYPE=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=wira_teknik
DB_SCHEMA=public

# Redis Settings
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_TTL=3600
REDIS_DB=0

# App Settings
NODE_ENV=development
APP_PORT=7001
APP_NAME="Wira Teknik"
APP_URL=http://localhost:7001
APP_SECRET=your_long_random_app_secret

# JWT Settings
JWT_SECRET=your_very_long_random_jwt_secret_min_32_chars
JWT_EXPIRY_HOURS=24

# Security & Proxy
TRUST_PROXY=true
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:8081

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
